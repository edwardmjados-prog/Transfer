WITH MASTER_TABLE AS (

SELECT 
    REPORT 
  , PUBLISH_DATE
  , PUBLISH_DATE_STRING
  , HOSPITAL_REPORT_ID
  , COREWELL_HEALTH_HOSPITAL
  , HOSPITAL_NAME
  , HOSPITAL_ADDRESS
  , HOSPITAL_CITY
  , HOSPITAL_STATE
  , HOSPITAL_ZIP_CODE
  , HOSPITAL_LONGITUDE
  , HOSPITAL_LATITUDE
  , MEASURE_CATEGORY
  , MEASURE_GROUP
  , MEASURE_NAME
  , HOSPITAL_MEASURE_RESULT::FLOAT AS HOSPITAL_MEASURE_RESULT
  , HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE
  , REPORT_OVERALL_SCORE_RANKING

FROM CARE_SILVER_DEV.EXPERIENCE.PERCEPTION_REPORTING_TABLE

WHERE REPORT = 'USNWR - Pediatric Specialties'
  AND MEASURE_NAME = 'SPECIALTY_SCORE'

),

DISTINCT_NAMES AS (

SELECT
    HOSPITAL_REPORT_ID
  , UPPER(MIN(HOSPITAL_NAME)) AS HOSPITAL_NAME

FROM MASTER_TABLE

GROUP BY
    HOSPITAL_REPORT_ID

),

NATIONAL_RANK AS (

SELECT 
    a.*
  , 'NATIONAL' AS HOSPITAL_RANKING_TYPE

FROM MASTER_TABLE a

