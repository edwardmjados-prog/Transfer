COHORT_RANK AS (

SELECT 
    a.*
  , 'COHORT (10 PEERS)' AS HOSPITAL_RANKING_TYPE

FROM MASTER_TABLE a

WHERE HOSPITAL_REPORT_ID IN (
      '6930206'
    , '6390900'
    , '6660635'
    , '6450820'
    , '6390695'
    , '6440480'
    , '6510540'
    , '6350007'
    , '6710340'
    , '6390687'
