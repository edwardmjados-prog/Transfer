          WHEN d.MEASURE_RESULT_STRING_FORMAT = 'DECIMAL_2' THEN TO_VARCHAR(ROUND(a.HOSPITAL_MEASURE_RESULT, 2))
          WHEN d.MEASURE_RESULT_STRING_FORMAT = 'DECIMAL_3' THEN TO_VARCHAR(ROUND(a.HOSPITAL_MEASURE_RESULT, 3))
          WHEN d.MEASURE_RESULT_STRING_FORMAT = 'DECIMAL_4' THEN TO_VARCHAR(ROUND(a.HOSPITAL_MEASURE_RESULT, 4))
          WHEN d.MEASURE_RESULT_STRING_FORMAT = 'PERCENT_0' THEN TO_VARCHAR(ROUND(a.HOSPITAL_MEASURE_RESULT * 100, 0)) || '%'
