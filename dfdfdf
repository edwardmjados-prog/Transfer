       WHEN a.FACILITY_ID = '230021' THEN 'COREWELL HEALTH LAKELAND HOSPITALS - ST. JOSEPH'
       WHEN a.FACILITY_ID = '230035' THEN 'COREWELL HEALTH GREENVILLE HOSPITAL'
       WHEN a.FACILITY_ID = '230038' THEN 'COREWELL HEALTH GRAND RAPIDS HOSPITALS - BLODGETT'
       WHEN a.FACILITY_ID = '230078' THEN 'COREWELL HEALTH WATERVLIET HOSPITAL'
       WHEN a.FACILITY_ID = '230089' THEN 'COREWELL HEALTH BEAUMONT GROSSE POINTE HOSPITAL'
       WHEN a.FACILITY_ID = '230093' THEN 'COREWELL HEALTH BIG RAPIDS HOSPITAL'
       WHEN a.FACILITY_ID = '230110' THEN 'COREWELL HEALTH LUDINGTON HOSPITAL'
       WHEN a.FACILITY_ID = '230130' THEN 'COREWELL HEALTH WILLIAM BEAUMONT UNIVERSITY HOSPITAL'
