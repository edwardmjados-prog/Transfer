    , d.MEASURE_DESCRIPTION AS MEASURE_DESCRIPTION
    , 'N/A' AS MEASURE_YEAR
    , a.HOSPITAL_MEASURE_RESULT
    , CASE
          WHEN d.MEASURE_RESULT_STRING_FORMAT = 'DECIMAL_0' THEN TO_VARCHAR(ROUND(a.HOSPITAL_MEASURE_RESULT, 0))
