WITH HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE AS (
SELECT
      PUBLISH_DATE
    , MEASURE_CATEGORY
    , MEASURE_GROUP
    , MEASURE_ID
    , LPAD(FACILITY_ID, 6, '0') as FACILITY_ID
    , CASE 
        WHEN MEASURE_CATEGORY = 'PERFORMANCE INFORMATION' THEN PERCENT_RANK() OVER (PARTITION BY PUBLISH_DATE, MEASURE_CATEGORY, MEASURE_GROUP, MEASURE_ID ORDER BY HOSPITAL_STANDARDIZED_MEASURE_SCORE)
        WHEN MEASURE_CATEGORY = 'MEASURE GROUP SCORES' AND MEASURE_ID IN ('MEASURE GROUP SCORE', 'HOSPITAL STANDARDIZED MEASURE GROUP SCORE') THEN PERCENT_RANK() OVER (PARTITION BY PUBLISH_DATE, MEASURE_CATEGORY, MEASURE_GROUP, MEASURE_ID ORDER BY HOSPITAL_MEASURE_RESULT) 
        WHEN MEASURE_CATEGORY = 'PERFORMANCE OVERVIEW' AND MEASURE_ID = 'HOSPITAL SUMMARY SCORE' THEN PERCENT_RANK() OVER (PARTITION BY PUBLISH_DATE, MEASURE_CATEGORY, MEASURE_GROUP, MEASURE_ID ORDER BY HOSPITAL_MEASURE_RESULT) 
      END AS HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE
FROM {{ref('CMS_STARS_REPORT_RANKING_FINAL')}}
WHERE HOSPITAL_MEASURE_RESULT IS NOT NULL
),

TABLE_1 AS (
SELECT
      a.REPORT
    , 'FINAL' AS REPORT_TYPE
    , 'ACTUAL' AS REPORT_TYPE_SUBTYPE
    , TO_DATE(a.PUBLISH_DATE) AS PUBLISH_DATE
    , TO_VARCHAR(EXTRACT(YEAR FROM TO_DATE(a.PUBLISH_DATE))) AS PUBLISH_DATE_STRING
    , LPAD(a.FACILITY_ID, 6, '0') AS HOSPITAL_REPORT_ID
    , LPAD(a.FACILITY_ID, 6, '0') AS HOSPITAL_CCN_ID 
    , CASE
       WHEN a.FACILITY_ID IN ('230003', '230020', '230021', '230035', '230038', '230078',
                     '230089', '230093', '230106', '230110', '230130', '230142', '230151',
                     '230176', '230269', '230270', '231323', '231338', '231339',
                     '230086') THEN 'TRUE'
       ELSE 'FALSE'
      END AS COREWELL_HEALTH_HOSPITAL
    , CASE
       WHEN a.FACILITY_ID IN ('230020', '230089', '230130', '230142', '230151', '230176', '230269', '230270') THEN 'COREWELL HEALTH EAST'
       WHEN a.FACILITY_ID IN ('230021', '230078') THEN 'COREWELL HEALTH SOUTH'
       WHEN a.FACILITY_ID IN ('230003', '230035', '230038', '230093', '230110', '231338', '230106', '231339', '230086', '231323') THEN 'COREWELL HEALTH WEST'
       ELSE 'N/A'
