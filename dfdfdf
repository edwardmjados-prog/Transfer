       WHEN a.FACILITY_ID = '230151' THEN 'COREWELL HEALTH FARMINGTON HILLS HOSPITAL'
       WHEN a.FACILITY_ID = '230176' THEN 'COREWELL HEALTH TRENTON HOSPITAL'
       WHEN a.FACILITY_ID = '230269' THEN 'COREWELL HEALTH BEAUMONT TROY HOSPITAL'
       WHEN a.FACILITY_ID = '230270' THEN 'COREWELL HEALTH TAYLOR HOSPITAL'
       WHEN a.FACILITY_ID = '231338' THEN 'COREWELL HEALTH GERBER HOSPITAL'
       WHEN a.FACILITY_ID = '230106' THEN 'COREWELL HEALTH GERBER HOSPITAL'
       WHEN a.FACILITY_ID = '231339' THEN 'COREWELL HEALTH PENNOCK HOSPITAL'
       WHEN a.FACILITY_ID = '230086' THEN 'COREWELL HEALTH REED CITY HOSPITAL'
