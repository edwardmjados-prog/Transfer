      END AS QUALITY_DOMAIN 
    , REPLACE(REPLACE(a.MEASURE_ID, ' ', '_'), '-', '_') AS MEASURE_ID
    , CASE
        WHEN a.MEASURE_ID = 'STAR RATING' THEN 'OVERALL'
        ELSE UPPER(d.MEASURE_NAME) 
