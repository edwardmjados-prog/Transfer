        WHEN ROUND(a.HOSPITAL_MEASURE_RESULT - LAG(a.HOSPITAL_MEASURE_RESULT) OVER (PARTITION BY a.FACILITY_ID, a.MEASURE_GROUP, a.MEASURE_ID ORDER BY TO_DATE(a.PUBLISH_DATE)), 3) > 0 AND d.DESIRED_DIRECTION = 'LOWER' THEN 'TREND INCREASE - BAD'
        WHEN ROUND(a.HOSPITAL_MEASURE_RESULT - LAG(a.HOSPITAL_MEASURE_RESULT) OVER (PARTITION BY a.FACILITY_ID, a.MEASURE_GROUP, a.MEASURE_ID ORDER BY TO_DATE(a.PUBLISH_DATE)), 3) < 0 AND d.DESIRED_DIRECTION = 'HIGHER' THEN 'TREND DECREASE - BAD'
        WHEN ROUND(a.HOSPITAL_MEASURE_RESULT - LAG(a.HOSPITAL_MEASURE_RESULT) OVER (PARTITION BY a.FACILITY_ID, a.MEASURE_GROUP, a.MEASURE_ID ORDER BY TO_DATE(a.PUBLISH_DATE)), 3) < 0 AND d.DESIRED_DIRECTION = 'LOWER' THEN 'TREND DECREASE - GOOD'
        WHEN ROUND(a.HOSPITAL_MEASURE_RESULT - LAG(a.HOSPITAL_MEASURE_RESULT) OVER (PARTITION BY a.FACILITY_ID, a.MEASURE_GROUP, a.MEASURE_ID ORDER BY TO_DATE(a.PUBLISH_DATE)), 3) = 0 AND d.DESIRED_DIRECTION = 'LOWER' THEN 'NO CHANGE'
        WHEN ROUND(a.HOSPITAL_MEASURE_RESULT - LAG(a.HOSPITAL_MEASURE_RESULT) OVER (PARTITION BY a.FACILITY_ID, a.MEASURE_GROUP, a.MEASURE_ID ORDER BY TO_DATE(a.PUBLISH_DATE)), 3) = 0 AND d.DESIRED_DIRECTION = 'LOWER' THEN 'NO CHANGE'
        ELSE NULL
      END AS TREND_DESCRIPTION
    , d.DATA_SOURCE_1
    --, d.DATA_SOURCE_2
    , (DENSE_RANK() OVER (ORDER BY a.PUBLISH_DATE DESC) - 1) * -1 AS LOOKBACK_PERIOD
    , a.LOADED_AT AS LOAD_DATE
FROM {{ref('CMS_STARS_REPORT_RANKING_FINAL')}} a

LEFT JOIN {{source('care_EXPERIENCE_BRONZE','BRONZE_HOSPITAL_GENERAL_INFORMATION')}} b
       ON LPAD(A.FACILITY_ID, 6, '0') = LPAD(B.FACILITY_ID, 6, '0') 

LEFT JOIN {{source('care_EXPERIENCE_BRONZE','BRONZE_HOSPITAL_GEOCODED')}} c
       ON LPAD(A.FACILITY_ID, 6, '0')  = LPAD(C.FACILITY_ID, 6, '0') 

LEFT JOIN {{source('care_EXPERIENCE_BRONZE','PERCEPTION_MEASURE_ATTRIBUTE_DIM')}} d
       ON a.REPORT = d.REPORT
      AND a.PUBLISH_DATE = d.PUBLISH_DATE
      AND a.MEASURE_CATEGORY = d.MEASURE_CATEGORY
      AND a.MEASURE_GROUP = d.MEASURE_GROUP
      AND a.MEASURE_ID = d.MEASURE_ID

LEFT JOIN {{ref('CMS_STARS_REPORT_RANKING_FINAL')}} e
       ON LPAD(A.FACILITY_ID, 6, '0')  = LPAD(E.FACILITY_ID, 6, '0') 
      AND a.PUBLISH_DATE = e.PUBLISH_DATE
      AND e.MEASURE_ID = 'PEER GROUP'

LEFT JOIN {{ref('CMS_STARS_REPORT_RANKING_FINAL')}} f
       ON LPAD(A.FACILITY_ID, 6, '0')  = LPAD(F.FACILITY_ID, 6, '0') 
      AND f.MEASURE_ID = 'STAR RATING'
      AND a.PUBLISH_DATE = f.PUBLISH_DATE

LEFT JOIN {{ref('CMS_STARS_REPORT_RANKING_FINAL')}} g
       ON LPAD(A.FACILITY_ID, 6, '0')  = LPAD(G.FACILITY_ID, 6, '0') 
      AND a.PUBLISH_DATE = g.PUBLISH_DATE
      AND a.MEASURE_GROUP = g.MEASURE_GROUP
      AND g.MEASURE_ID = 'HOSPITAL MEASURE GROUP WEIGHT'

LEFT JOIN HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE p
       ON a.PUBLISH_DATE = p.PUBLISH_DATE
      AND a.MEASURE_CATEGORY = p.MEASURE_CATEGORY
      AND a.MEASURE_GROUP = p.MEASURE_GROUP
      AND a.MEASURE_ID = p.MEASURE_ID
      AND LPAD(A.FACILITY_ID, 6, '0') = LPAD(P.FACILITY_ID, 6, '0')

WHERE a.FACILITY_ID IN ('230038', '230021')

)


SELECT
      a.REPORT
    , a.REPORT_TYPE
    , a.REPORT_TYPE_SUBTYPE
    , a.PUBLISH_DATE
    , a.PUBLISH_DATE_STRING
    , a.HOSPITAL_REPORT_ID
    , a.HOSPITAL_CCN_ID 
    , a.COREWELL_HEALTH_HOSPITAL
    , a.COREWELL_HEALTH_REGION
    , a.HOSPITAL_NAME
    , a.HOSPITAL_ADDRESS
    , a.HOSPITAL_CITY
    , a.HOSPITAL_STATE
    , a.HOSPITAL_ZIP_CODE
    --, a.HOSPITAL_TELEPHONE_NUMBER
    , a.HOSPITAL_TYPE
    , a.HOSPITAL_LATITUDE
    , a.HOSPITAL_LONGITUDE
    , a.HOSPITAL_COHORT_GROUP
    , a.REPORT_OVERALL_SCORE_RANKING
    , a.MEASURE_LEVEL 
    , a.QUALITY_DOMAIN 
    , CASE
       WHEN a.MEASURE_ID = 'STAR_RATING' THEN 'OVERALL'
       ELSE a.MEASURE_ID
      END AS MEASURE_ID
    , a.MEASURE_NAME
    , a.SUBMEASURE_NAME
    , a.MEASURE_DESCRIPTION
    , a.MEASURE_YEAR
    , a.HOSPITAL_MEASURE_RESULT
    , a.HOSPITAL_MEASURE_RESULT_STRING
    , a.HOSPITAL_STANDARDIZED_MEASURE_SCORE
    , a.NATIONAL_MEAN_SCORE
    , a.ORIGINAL_ZSCORE
    , a.MODIFIED_ZSCORE
    , a.NATIONAL_STANDARD_DEVIATION
    , a.MEASURE_WEIGHT_IN_DOMAIN
    , a.DOMAIN_WEIGHT
    , a.OVERALL_MEASURE_WEIGHT
    , a.HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE
    , a.HOSPITAL_MEASURE_RESULT_POP_CHANGE
    , a.HOSPITAL_STANDARDIZED_MEASURE_SCORE_POP_CHANGE
    --, a.GOAL
    --, a.GPA
    , a.REPORTING_PERIOD_START_DATE
    , a.REPORTING_PERIOD_END_DATE
    , a.MEASURE_RESULT_DESIRED_DIRECTION
    , a.TREND_DESCRIPTION
    , CASE
       WHEN a.MEASURE_LEVEL = 'OVERALL' AND a.MEASURE_ID = 'STAR_RATING' AND a.HOSPITAL_MEASURE_RESULT = '5' THEN 'GROUP 1 - DARK BLUE'
       WHEN a.MEASURE_LEVEL = 'OVERALL' AND a.MEASURE_ID = 'STAR_RATING' AND a.HOSPITAL_MEASURE_RESULT = '4' THEN 'GROUP 2 - LIGHT BLUE'
       WHEN a.MEASURE_LEVEL = 'OVERALL' AND a.MEASURE_ID = 'STAR_RATING' AND a.HOSPITAL_MEASURE_RESULT = '3' THEN 'GROUP 3 - TAN'
       WHEN a.MEASURE_LEVEL = 'OVERALL' AND a.MEASURE_ID = 'STAR_RATING' AND a.HOSPITAL_MEASURE_RESULT = '2' THEN 'GROUP 4 - BURNT ORANGE'
       WHEN a.MEASURE_LEVEL = 'OVERALL' AND a.MEASURE_ID = 'STAR_RATING' AND a.HOSPITAL_MEASURE_RESULT = '1' THEN 'GROUP 5 - CAYENNE ORANGE'

       WHEN a.MEASURE_LEVEL IN ('DOMAIN', 'MEASURE') AND a.HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE >= 0.90 THEN 'GROUP 1 - DARK BLUE'
       WHEN a.MEASURE_LEVEL IN ('DOMAIN', 'MEASURE') AND a.HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE < 0.90 AND a.HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE >= 0.75 THEN 'GROUP 2 - LIGHT BLUE'
       WHEN a.MEASURE_LEVEL IN ('DOMAIN', 'MEASURE') AND a.HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE < 0.75 AND a.HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE >= 0.50 THEN 'GROUP 3 - TAN'
       WHEN a.MEASURE_LEVEL IN ('DOMAIN', 'MEASURE') AND a.HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE < 0.50 AND a.HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE >= 0.25 THEN 'GROUP 4 - BURNT ORANGE'
       WHEN a.MEASURE_LEVEL IN ('DOMAIN', 'MEASURE') AND a.HOSPITAL_STANDARDIZED_MEASURE_PERCENTILE < 0.25 THEN 'GROUP 5 - CAYENNE ORANGE'
       ELSE 'WHITE'
      END AS COLOR_GROUP
    , a.DATA_SOURCE_1
    --, a.DATA_SOURCE_2
    , a.LOOKBACK_PERIOD
    , a.LOAD_DATE
FROM TABLE_1 a
