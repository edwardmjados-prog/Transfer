    , ROUND(a.MEASURE_WEIGHT, 3) AS MEASURE_WEIGHT_IN_DOMAIN
    , ROUND(g.HOSPITAL_MEASURE_RESULT, 3) AS DOMAIN_WEIGHT
    , ROUND(g.HOSPITAL_MEASURE_RESULT, 3) * ROUND(a.MEASURE_WEIGHT, 3) AS OVERALL_MEASURE_WEIGHT
